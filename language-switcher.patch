diff --git a/src/app/globals.css b/src/app/globals.css
index b628687..d76ec74 100644
--- a/src/app/globals.css
+++ b/src/app/globals.css
@@ -198,4 +198,71 @@
     background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
     animation: shimmer 1.4s infinite;
   }
+
+  /* ---- draggable floating chess-piece particles (hero background) ---- */
+  @keyframes particle-rise {
+    from { transform: translateY(0) rotate(0deg); }
+    to   { transform: translateY(-110vh) rotate(20deg); }
+  }
+  .particle-piece {
+    position: absolute;
+    color: var(--color-accent);
+    /* more visible than a faint background texture, still reads as ambient */
+    opacity: 0.32;
+    filter: drop-shadow(0 0 8px rgba(74, 222, 128, 0.45));
+    animation-name: particle-rise;
+    animation-timing-function: linear;
+    animation-iteration-count: infinite;
+    user-select: none;
+    cursor: grab;
+    pointer-events: auto;
+  }
+  .particle-piece.dragging {
+    animation: none;
+    opacity: 0.95;
+    cursor: grabbing;
+    z-index: 50;
+    transition: none;
+    /* ~15%+ stronger glow than the resting pieces, plus an outer halo
+       the resting pieces don't have, so the held piece clearly stands out */
+    filter:
+      drop-shadow(0 0 9.5px rgba(74, 222, 128, 0.52))
+      drop-shadow(0 0 20px rgba(74, 222, 128, 0.28));
+  }
+
+  /* ---- glow hover for cards / buttons (optional utilities) ---- */
+  .glow-card {
+    transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
+  }
+  .glow-card:hover {
+    border-color: rgba(74, 222, 128, 0.5);
+    box-shadow: 0 0 24px rgba(74, 222, 128, 0.22), 0 0 48px rgba(74, 222, 128, 0.1);
+    transform: translateY(-3px);
+  }
+  .glow-btn {
+    transition: box-shadow 0.25s ease, transform 0.2s ease;
+  }
+  .glow-btn:hover {
+    box-shadow: 0 0 18px rgba(74, 222, 128, 0.55), 0 0 36px rgba(74, 222, 128, 0.28);
+    transform: translateY(-1px);
+  }
+  .glow-btn:active {
+    transform: translateY(0);
+  }
+
+  /* ---- suppress Google Translate's default banner/UI — we drive
+     translation through our own dropdown in LanguageSwitcher ---- */
+  .goog-te-banner-frame,
+  .goog-te-balloon-frame,
+  .goog-tooltip,
+  .goog-te-gadget-icon {
+    display: none !important;
+  }
+  body {
+    top: 0 !important;
+  }
+  .goog-text-highlight {
+    background: none !important;
+    box-shadow: none !important;
+  }
 }
